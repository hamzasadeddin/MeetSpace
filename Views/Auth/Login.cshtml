@model MeetingRoomBooking.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MeetSpace — Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --primary: #5b6af7;
            --primary-dark: #3d4fd6;
            --primary-light: #eef0ff;
            --accent: #ff7f50;
            --bg: #f7f8ff;
            --surface: #ffffff;
            --border: #e4e7ff;
            --text: #1e1f4b;
            --text-secondary: #6b7280;
            --radius: 18px;
            --radius-sm: 10px;
            --shadow: 0 4px 24px rgba(91,106,247,0.10);
            --shadow-lg: 0 12px 48px rgba(91,106,247,0.18);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Nunito', sans-serif;
            background: var(--bg);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background-image: radial-gradient(ellipse at 15% 15%, rgba(91,106,247,0.10) 0%, transparent 55%), radial-gradient(ellipse at 85% 85%, rgba(255,127,80,0.08) 0%, transparent 55%);
        }

        .login-wrapper {
            width: 100%;
            max-width: 440px;
            padding: 1.5rem;
        }

        .login-card {
            background: var(--surface);
            border: 1.5px solid var(--border);
            border-radius: 24px;
            padding: 2.8rem 2.4rem;
            box-shadow: var(--shadow-lg);
        }

        .brand {
            font-family: 'Clash Display', sans-serif;
            font-size: 1.6rem;
            font-weight: 700;
            color: var(--primary);
            letter-spacing: -0.5px;
            text-align: center;
            margin-bottom: .3rem;
        }

        .brand-sub {
            text-align: center;
            color: var(--text-secondary);
            font-size: .88rem;
            margin-bottom: 2.2rem;
        }

        .form-label {
            color: var(--text-secondary);
            font-weight: 700;
            font-size: .78rem;
            text-transform: uppercase;
            letter-spacing: .06em;
        }

        .form-control {
            background: #f7f8ff !important;
            border: 1.5px solid var(--border) !important;
            border-radius: var(--radius-sm) !important;
            color: var(--text) !important;
            font-family: 'Nunito', sans-serif;
            font-size: .93rem;
            padding: .72rem 1rem;
            transition: border-color .2s, box-shadow .2s;
        }

            .form-control:focus {
                border-color: var(--primary) !important;
                box-shadow: 0 0 0 3px rgba(91,106,247,0.12) !important;
                background: #fff !important;
                outline: none;
            }

            .form-control::placeholder {
                color: #aab0cc;
            }

        .input-icon-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: .95rem;
            top: 50%;
            transform: translateY(-50%);
            color: #b0b7d4;
            font-size: .88rem;
            pointer-events: none;
        }

            .input-icon + .form-control {
                padding-left: 2.4rem;
            }

        .btn-login {
            background: linear-gradient(135deg, var(--primary), var(--primary-dark));
            border: none;
            border-radius: var(--radius-sm);
            color: #fff;
            font-family: 'Nunito', sans-serif;
            font-size: .95rem;
            font-weight: 700;
            padding: .75rem;
            width: 100%;
            box-shadow: 0 4px 16px rgba(91,106,247,0.30);
            transition: all .25s ease;
            cursor: pointer;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 28px rgba(91,106,247,0.40);
            }

        .alert-danger {
            background: rgba(239,68,68,0.05);
            border: 1.5px solid rgba(239,68,68,0.2);
            border-radius: var(--radius-sm);
            color: #dc2626;
            font-size: .88rem;
            font-weight: 600;
            padding: .75rem 1rem;
        }

        .divider {
            display: flex;
            align-items: center;
            gap: .75rem;
            margin: 1.6rem 0 1.2rem;
            color: var(--text-secondary);
            font-size: .78rem;
            font-weight: 700;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--border);
            }

        .company-chips {
            display: flex;
            flex-wrap: wrap;
            gap: .5rem;
            justify-content: center;
        }

        .company-chip {
            background: var(--primary-light);
            border: 1.5px solid rgba(91,106,247,0.15);
            border-radius: 20px;
            color: var(--primary);
            font-size: .72rem;
            font-weight: 700;
            padding: 3px 12px;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card">

            <div class="brand"><i class="fas fa-calendar-check me-2"></i>MeetSpace</div>
            <div class="brand-sub">Sign in to manage your meeting rooms</div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-danger mb-4">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form asp-controller="Auth" asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <div class="input-icon-wrapper mt-1">
                        <i class="fas fa-envelope input-icon"></i>
                        <input asp-for="Email" type="email" class="form-control"
                               placeholder="you@company.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <div class="input-icon-wrapper mt-1">
                        <i class="fas fa-lock input-icon"></i>
                        <input asp-for="Password" type="password" class="form-control"
                               placeholder="••••••••" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn-login">
                    <i class="fas fa-sign-in-alt me-2"></i>Sign In
                </button>
            </form>

            <div class="divider">Supported Companies</div>
            <div class="company-chips">
                <span class="company-chip">Kia Jordan</span>
                <span class="company-chip">Kia Iraq</span>
                <span class="company-chip">GAC Jordan</span>
                <span class="company-chip">GAC Iraq</span>
                <span class="company-chip">BYD Iraq</span>
                <span class="company-chip">Isuzu</span>
            </div>

        </div>
    </div>
</body>
</html>