@model MeetingRoomBooking.Models.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MeetSpace — Sign In</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --navy: #1a2744;
            --navy-deep: #111c33;
            --navy-mid: #243156;
            --gold: #c9a84c;
            --gold-light: #e2c47a;
            --gold-pale: #f5edd8;
            --surface: #ffffff;
            --border: #dde0ea;
            --text: #111c33;
            --text-secondary: #4a5568;
            --text-muted: #8896aa;
            --danger: #b91c1c;
            --shadow-lg: 0 12px 48px rgba(26,39,68,0.16);
            --radius-sm: 9px;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        html {
            height: 100%;
            overflow-y: auto;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--navy);
            min-height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow-x: hidden;
            padding: 2rem 0;
        }

            body::before {
                content: '';
                position: fixed;
                width: 600px;
                height: 600px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(201,168,76,0.08), transparent 65%);
                top: -200px;
                right: -150px;
                pointer-events: none;
                animation: orb 8s ease-in-out infinite;
            }

            body::after {
                content: '';
                position: fixed;
                width: 500px;
                height: 500px;
                border-radius: 50%;
                background: radial-gradient(circle, rgba(255,255,255,0.03), transparent 65%);
                bottom: -150px;
                left: -100px;
                pointer-events: none;
                animation: orb 10s ease-in-out infinite reverse;
            }

        @@keyframes orb {
            0%, 100% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.12) translate(20px,-20px);
            }
        }

        .login-wrapper {
            width: 100%;
            max-width: 460px;
            padding: 1.5rem;
            position: relative;
            z-index: 1;
        }

        .login-card {
            background: var(--surface);
            border: 1px solid rgba(201,168,76,0.2);
            border-radius: 22px;
            padding: 3rem 2.6rem;
            box-shadow: var(--shadow-lg);
            animation: cardIn .5s cubic-bezier(.34,1.56,.64,1) both;
        }

        @@keyframes cardIn {
            from {
                opacity: 0;
                transform: translateY(30px) scale(0.97);
            }

            to {
                opacity: 1;
                transform: none;
            }
        }

        .login-card::before {
            content: '';
            display: block;
            height: 3px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
            border-radius: 3px;
            margin-bottom: 2rem;
        }

        .brand-logo-wrap {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 0;
            min-height: 0;
        }

            .brand-logo-wrap img {
                height: 150px;
                width: auto;
                max-width: 100%;
                object-fit: contain;
                display: block;
            }

        .brand-tagline {
            text-align: center;
            color: var(--text-secondary);
            font-size: .84rem;
            margin-bottom: .2rem;
            margin-top: .4rem;
        }

        .brand-platform {
            text-align: center;
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.7rem;
            font-weight: 700;
            color: var(--navy);
            letter-spacing: .5px;
            margin-bottom: 1.4rem;
        }

        .form-label {
            color: var(--text-secondary);
            font-weight: 600;
            font-size: .76rem;
            text-transform: uppercase;
            letter-spacing: .07em;
        }

        .form-control {
            background: #f4f5f8 !important;
            border: 1.5px solid var(--border) !important;
            border-radius: var(--radius-sm) !important;
            color: var(--text) !important;
            font-family: 'DM Sans', sans-serif;
            font-size: .93rem;
            padding: .72rem 1rem;
            transition: border-color .2s, box-shadow .2s;
        }

            .form-control:focus {
                border-color: var(--navy) !important;
                box-shadow: 0 0 0 3px rgba(26,39,68,0.10) !important;
                background: #fff !important;
                outline: none;
            }

            .form-control::placeholder {
                color: #9aa5b8;
            }

        .input-icon-wrapper {
            position: relative;
        }

        .input-icon {
            position: absolute;
            left: .95rem;
            top: 50%;
            transform: translateY(-50%);
            color: #9aa5b8;
            font-size: .85rem;
            pointer-events: none;
        }

            .input-icon + .form-control {
                padding-left: 2.4rem;
            }

        .btn-login {
            background: linear-gradient(135deg, var(--navy), var(--navy-mid));
            border: none;
            border-radius: var(--radius-sm);
            color: #fff;
            font-family: 'DM Sans', sans-serif;
            font-size: .93rem;
            font-weight: 700;
            padding: .78rem;
            width: 100%;
            box-shadow: 0 4px 16px rgba(26,39,68,0.30);
            transition: all .25s ease;
            cursor: pointer;
            position: relative;
            overflow: hidden;
        }

            .btn-login::after {
                content: '';
                position: absolute;
                inset: 0;
                background: linear-gradient(135deg, transparent 40%, rgba(201,168,76,0.15));
                opacity: 0;
                transition: opacity .25s;
            }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 28px rgba(26,39,68,0.40);
            }

                .btn-login:hover::after {
                    opacity: 1;
                }

        .alert-login-error {
            background: rgba(185,28,28,0.05);
            border: 1.5px solid rgba(185,28,28,0.18);
            border-radius: var(--radius-sm);
            color: var(--danger);
            font-size: .86rem;
            font-weight: 600;
            padding: .72rem 1rem;
            margin-bottom: 1.2rem;
        }

        .divider {
            display: flex;
            align-items: center;
            gap: .75rem;
            margin: 1.6rem 0 1.1rem;
            color: var(--text-muted);
            font-size: .74rem;
            font-weight: 600;
            letter-spacing: .06em;
            text-transform: uppercase;
        }

            .divider::before, .divider::after {
                content: '';
                flex: 1;
                height: 1px;
                background: var(--border);
            }

        .company-chips {
            display: flex;
            flex-wrap: wrap;
            gap: .45rem;
            justify-content: center;
        }

        .company-chip {
            background: rgba(26,39,68,0.06);
            border: 1.5px solid rgba(26,39,68,0.12);
            border-radius: 20px;
            color: var(--navy);
            font-size: .70rem;
            font-weight: 700;
            padding: 3px 12px;
            letter-spacing: .03em;
        }

        .gold-line {
            height: 2px;
            background: linear-gradient(90deg, transparent, var(--gold), transparent);
            border-radius: 2px;
            margin-top: 2rem;
            opacity: .5;
        }
    </style>
</head>
<body>
    <div class="login-wrapper">
        <div class="login-card">

            <div class="brand-logo-wrap">
                <img src="data:image/png;base64," alt="Alayyan" />
            </div>

            <div class="brand-tagline">Welcome to</div>
            <div class="brand-platform">MeetSpace</div>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-login-error">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <div>@error.ErrorMessage</div>
                    }
                </div>
            }

            <form asp-controller="Auth" asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label">Email Address</label>
                    <div class="input-icon-wrapper mt-1">
                        <i class="fas fa-envelope input-icon"></i>
                        <input asp-for="Email" type="email" class="form-control"
                               placeholder="you@alayyan.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Password</label>
                    <div class="input-icon-wrapper mt-1">
                        <i class="fas fa-lock input-icon"></i>
                        <input asp-for="Password" type="password" class="form-control"
                               placeholder="••••••••" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn-login">
                    <i class="fas fa-sign-in-alt me-2"></i>Sign In
                </button>
            </form>

            <div class="divider">Supported Companies</div>
            <div class="company-chips">
                <span class="company-chip">Kia Jordan</span>
                <span class="company-chip">Kia Iraq</span>
                <span class="company-chip">GAC Jordan</span>
                <span class="company-chip">GAC Iraq</span>
                <span class="company-chip">BYD Iraq</span>
                <span class="company-chip">Isuzu</span>
            </div>

            <div class="gold-line"></div>

        </div>
    </div>
</body>
</html>
