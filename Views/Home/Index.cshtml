@{
    ViewData["Title"] = "Home";
    var availableNow = (int)(ViewBag.AvailableNow ?? 0);
    var totalRooms = (int)(ViewBag.TotalRooms ?? 0);
    var eventsJson = (string)(ViewBag.CalendarEvents ?? "[]");
}

@section HeadExtra {
    <link href='https://cdn.jsdelivr.net/npm/fullcalendar@@6.1.10/index.global.min.css' rel='stylesheet' />
    <style>
        #mainCalendar {
            font-family: 'Nunito', sans-serif;
        }

            #mainCalendar .fc-toolbar {
                padding: 1.5rem 1.8rem 1rem;
                flex-wrap: wrap;
                gap: 0.6rem;
            }

            #mainCalendar .fc-toolbar-title {
                font-family: 'Clash Display', sans-serif;
                font-size: 1.45rem !important;
                font-weight: 700 !important;
                color: var(--text) !important;
                letter-spacing: -0.3px;
            }

            #mainCalendar .fc-button-group .fc-button {
                border-radius: 0 !important;
            }

                #mainCalendar .fc-button-group .fc-button:first-child {
                    border-radius: var(--radius-sm) 0 0 var(--radius-sm) !important;
                }

                #mainCalendar .fc-button-group .fc-button:last-child {
                    border-radius: 0 var(--radius-sm) var(--radius-sm) 0 !important;
                }

                #mainCalendar .fc-button-group .fc-button:only-child {
                    border-radius: var(--radius-sm) !important;
                }

            #mainCalendar .fc-button-primary {
                background: var(--surface2) !important;
                border: 1.5px solid var(--border) !important;
                color: var(--text-secondary) !important;
                font-family: 'Nunito', sans-serif !important;
                font-size: 0.82rem !important;
                font-weight: 700 !important;
                padding: 0.42rem 1rem !important;
                box-shadow: none !important;
                transition: all 0.2s ease !important;
                text-transform: none !important;
                letter-spacing: 0 !important;
            }

                #mainCalendar .fc-button-primary:hover {
                    background: var(--primary-light) !important;
                    border-color: var(--primary) !important;
                    color: var(--primary) !important;
                }

                #mainCalendar .fc-button-primary:not(:disabled).fc-button-active,
                #mainCalendar .fc-button-primary:not(:disabled):active {
                    background: var(--primary) !important;
                    border-color: var(--primary) !important;
                    color: #fff !important;
                    box-shadow: 0 4px 12px rgba(91,106,247,0.25) !important;
                }

            #mainCalendar .fc-prev-button,
            #mainCalendar .fc-next-button {
                padding: 0.42rem 0.75rem !important;
            }

            #mainCalendar .fc-today-button {
                background: var(--primary-light) !important;
                border-color: rgba(91,106,247,0.25) !important;
                color: var(--primary) !important;
            }

                #mainCalendar .fc-today-button:hover {
                    background: var(--primary) !important;
                    border-color: var(--primary) !important;
                    color: #fff !important;
                }

            #mainCalendar .fc-col-header-cell {
                background: var(--surface2);
                border-color: var(--border) !important;
                padding: 0.55rem 0;
            }

            #mainCalendar .fc-col-header-cell-cushion {
                color: var(--primary) !important;
                font-size: 0.72rem !important;
                font-weight: 800 !important;
                text-transform: uppercase;
                letter-spacing: 0.07em;
                text-decoration: none !important;
            }

            #mainCalendar .fc-daygrid-day-number {
                color: var(--text-secondary) !important;
                font-size: 0.82rem !important;
                font-weight: 600 !important;
                text-decoration: none !important;
                padding: 6px 8px !important;
            }

            #mainCalendar .fc-daygrid-day.fc-day-today {
                background: var(--primary-light) !important;
            }

                #mainCalendar .fc-daygrid-day.fc-day-today .fc-daygrid-day-number {
                    color: #fff !important;
                    background: var(--primary);
                    border-radius: 50%;
                    width: 26px;
                    height: 26px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    margin: 4px;
                }

            #mainCalendar .fc-scrollgrid,
            #mainCalendar td,
            #mainCalendar th {
                border-color: var(--border) !important;
            }

            #mainCalendar .fc-event {
                border: none !important;
                border-radius: 6px !important;
                font-family: 'Nunito', sans-serif !important;
                font-size: 0.76rem !important;
                font-weight: 700 !important;
                cursor: pointer !important;
                transition: transform 0.15s, filter 0.15s !important;
                box-shadow: none !important;
            }

                #mainCalendar .fc-event:hover {
                    filter: brightness(1.1) !important;
                    transform: translateY(-1px) scale(1.02) !important;
                }

            #mainCalendar .fc-event-title {
                font-family: 'Nunito', sans-serif !important;
                font-weight: 700 !important;
                font-size: 0.76rem !important;
            }

            #mainCalendar .fc-event-time {
                font-family: 'Nunito', sans-serif !important;
                font-weight: 600 !important;
                font-size: 0.70rem !important;
            }

            #mainCalendar .fc-timegrid-slot-label-cushion {
                font-size: 0.72rem !important;
                color: var(--text-secondary) !important;
                font-weight: 600 !important;
                padding-right: 8px !important;
            }

            #mainCalendar .fc-timegrid-now-indicator-line {
                border-color: var(--accent) !important;
                border-width: 2px !important;
            }

            #mainCalendar .fc-timegrid-now-indicator-arrow {
                border-top-color: var(--accent) !important;
                border-bottom-color: var(--accent) !important;
            }

            #mainCalendar .fc-daygrid-more-link {
                font-size: 0.72rem !important;
                font-weight: 700 !important;
                color: var(--primary) !important;
            }

        .calendar-card {
            background: var(--surface);
            border: 1.5px solid var(--border);
            border-radius: var(--radius);
            box-shadow: var(--shadow-lg);
            overflow: hidden;
        }

        #calLegend > div {
            color: var(--text) !important;
        }
    </style>
}

<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-5">

            <div class="col-lg-6">
                <div class="section-badge fade-up">✦ Smart Booking Platform</div>
                <h1 class="hero-title mt-3 fade-up delay-1">
                    Book Your<br /><span>Perfect</span><br />Meeting Room
                </h1>
                <p class="hero-subtitle mt-4 fade-up delay-2">
                    Reserve conference rooms, collaborate with your team,
                    and manage your schedule — all in one beautiful space.
                </p>
                <div class="d-flex gap-3 mt-5 fade-up delay-3">
                    <a asp-controller="Booking" asp-action="Index" class="btn btn-primary btn-lg">
                        <i class="fas fa-door-open me-2"></i>Browse Rooms
                    </a>
                    <a asp-controller="Booking" asp-action="Create" class="btn btn-outline-primary btn-lg">
                        <i class="fas fa-plus me-2"></i>Quick Book
                    </a>
                </div>
                <div class="row mt-4 g-3 fade-up delay-4" style="padding-bottom:2.5rem">
                    <div class="col-4">
                        <div class="stat-card">
                            <span class="stat-number">@availableNow</span>
                            <div class="stat-label">Available Now</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-card">
                            <span class="stat-number">@totalRooms</span>
                            <div class="stat-label">Total Rooms</div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="stat-card">
                            <span class="stat-number">24/7</span>
                            <div class="stat-label">Booking Access</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6 text-center d-none d-lg-block fade-up delay-2">
                <div class="hero-illustration">
                    <svg width="420" height="360" viewBox="0 0 420 360" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="30" y="40" width="360" height="280" rx="24" fill="#f0f2ff" stroke="#c7ccff" stroke-width="1.5" />
                        <rect x="50" y="70" width="150" height="110" rx="14" fill="white" stroke="#e4e7ff" stroke-width="1.2" />
                        <rect x="220" y="70" width="150" height="110" rx="14" fill="white" stroke="#e4e7ff" stroke-width="1.2" />
                        <rect x="50" y="200" width="320" height="90" rx="14" fill="white" stroke="#e4e7ff" stroke-width="1.2" />
                        <circle cx="108" cy="135" r="22" fill="#eef0ff" />
                        <text x="98" y="142" font-size="18">📅</text>
                        <rect x="62" y="157" width="100" height="7" rx="3.5" fill="#5b6af7" opacity="0.7" />
                        <rect x="62" y="169" width="65" height="5" rx="2.5" fill="#e4e7ff" />
                        <circle cx="278" cy="135" r="22" fill="#fff0eb" />
                        <text x="268" y="142" font-size="18">🚀</text>
                        <rect x="232" y="157" width="100" height="7" rx="3.5" fill="#ff7f50" opacity="0.7" />
                        <rect x="232" y="169" width="65" height="5" rx="2.5" fill="#ffe4d9" />
                        <circle cx="74" cy="222" r="12" fill="#eef0ff" />
                        <text x="67" y="227" font-size="11">✓</text>
                        <rect x="96" y="212" width="180" height="8" rx="4" fill="#5b6af7" opacity="0.5" />
                        <rect x="96" y="226" width="120" height="6" rx="3" fill="#e4e7ff" />
                        <rect x="296" y="212" width="60" height="26" rx="8" fill="#22c55e" opacity="0.15" />
                        <text x="307" y="230" font-size="10" fill="#22c55e" font-weight="bold">Done</text>
                    </svg>
                </div>
            </div>

        </div>
    </div>
</section>

<section class="calendar-section" style="padding-top:6rem">
    <div class="container">
        <div class="section-header fade-up">
            <div class="section-badge">Live Schedule</div>
            <h2 class="section-title">Room Booking Calendar</h2>
            <p style="color:var(--text-secondary);margin-top:.4rem;font-size:.95rem">
                Click any event to view details · Click any date to book that day
            </p>
        </div>

        <div id="calLegend"
             class="d-flex flex-wrap gap-2 justify-content-center mb-4 fade-up delay-1">
        </div>

        <div class="calendar-card fade-up delay-2">
            <div id="mainCalendar"></div>
        </div>
    </div>
</section>

<div class="booking-modal-overlay" id="bookingModal"
     style="display:none" onclick="closeModalOnBackdrop(event)">
    <div class="booking-modal">
        <button class="modal-close-btn"
                onclick="document.getElementById('bookingModal').style.display='none'">
            ✕
        </button>
        <div class="modal-badge mb-3">
            <i class="fas fa-calendar-check me-1"></i>Booking Details
        </div>
        <h4 id="modal-subject"
            style="font-family:'Clash Display',sans-serif;font-size:1.3rem;font-weight:700;
               color:var(--text);margin-bottom:1.2rem;line-height:1.25;
               padding-right:2rem"></h4>
        <div id="modal-details"></div>
    </div>
</div>

<div class="booking-modal-overlay" id="quickBookModal"
     style="display:none" onclick="closeQuickBookBackdrop(event)">
    <div class="booking-modal" style="max-width:520px">
        <button class="modal-close-btn"
                onclick="document.getElementById('quickBookModal').style.display='none'">
            ✕
        </button>

        <div class="modal-badge mb-3">
            <i class="fas fa-calendar-plus me-1"></i>Quick Book
        </div>
        <h4 id="qb-date-heading"
            style="font-family:'Clash Display',sans-serif;font-size:1.2rem;font-weight:700;
               color:var(--text);margin-bottom:1.4rem;padding-right:2rem">
            Book a Room
        </h4>

        <div class="mb-4">
            <label style="color:var(--text-secondary);font-weight:700;font-size:.78rem;
                     text-transform:uppercase;letter-spacing:.07em;display:block;
                     margin-bottom:.45rem">
                Select Room
            </label>
            <select id="qb-room" class="form-select">
                <option value="">— Any room (choose on next page) —</option>
                @if (ViewBag.RoomsList != null)
                {
                    foreach (var r in ViewBag.RoomsList)
                    {
                        <option value="@r.Room_Id">@r.Room_Name</option>
                    }
                }
            </select>
        </div>

        <div class="mb-4">
            <label style="color:var(--text-secondary);font-weight:700;font-size:.78rem;
                     text-transform:uppercase;letter-spacing:.07em;display:block;
                     margin-bottom:.45rem">
                Selected Date
            </label>
            <div id="qb-date-display"
                 style="background:var(--primary-light);border:1.5px solid rgba(91,106,247,0.2);
                  border-radius:var(--radius-sm);padding:.72rem 1rem;font-weight:700;
                  color:var(--primary);font-size:.93rem">
                —
            </div>
        </div>

        <div class="d-flex gap-3 mt-2">
            <button type="button" class="btn btn-primary flex-grow-1"
                    onclick="submitQuickBook()">
                <i class="fas fa-arrow-right me-2"></i>Continue to Booking
            </button>
            <button type="button" class="btn btn-outline-primary"
                    onclick="document.getElementById('quickBookModal').style.display='none'">
                Cancel
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@@6.1.10/index.global.min.js'></script>
    <script>
        (function () {

          const raw = @Html.Raw(eventsJson);

          const palette = [
            '#5b6af7','#ff7f50','#22c55e',
            '#f59e0b','#8b5cf6','#06b6d4','#ec4899'
          ];
          const roomColor = {};
          let ci = 0;
          function getColor(room) {
            if (!room) return palette[0];
            if (!roomColor[room]) roomColor[room] = palette[ci++ % palette.length];
            return roomColor[room];
          }

          (raw || []).forEach(e => getColor(e.room));

          const fcEvents = (raw || []).map(e => ({
            id:              e.id,
            title:           e.title || 'Meeting',
            start:           e.start,
            end:             e.end,
            backgroundColor: getColor(e.room || ''),
            borderColor:     'transparent',
            textColor:       '#fff',
            extendedProps: {
              room:        e.room,
              organizer:   e.organizer,
              description: e.description,
              location:    e.location,
              status:      e.status
            }
          }));

          function buildLegend() {
            const el = document.getElementById('calLegend');
            if (!el) return;
            el.innerHTML = '';
            Object.entries(roomColor).forEach(([room, color]) => {
              const pill = document.createElement('div');
              pill.style.cssText = `
                display:inline-flex;align-items:center;gap:7px;
                background:var(--surface);border:1.5px solid var(--border);
                border-radius:20px;padding:5px 14px;
                font-family:'Nunito',sans-serif;font-size:.76rem;
                font-weight:700;color:var(--text);
                box-shadow:0 1px 4px rgba(91,106,247,0.06);
              `;
              pill.innerHTML =
                `<span style="width:9px;height:9px;border-radius:50%;
                              background:${color};display:inline-block;
                              flex-shrink:0;box-shadow:0 0 0 2px ${color}33">
                 </span>${room}`;
              el.appendChild(pill);
            });
          }

          function fmt(dateStr) {
            if (!dateStr) return '—';
            return new Date(dateStr).toLocaleString('en-GB', {
              dateStyle: 'medium', timeStyle: 'short'
            });
          }

          function detailRow(iconClass, label, value) {
            if (!value) return '';
            return `
              <div class="modal-detail-row">
                <div class="modal-detail-icon"><i class="${iconClass}"></i></div>
                <div>
                  <div class="modal-detail-label">${label}</div>
                  <div class="modal-detail-value">${value}</div>
                </div>
              </div>`;
          }

          let _selectedDate = null;

          document.addEventListener('DOMContentLoaded', function () {
            const calEl = document.getElementById('mainCalendar');
            if (!calEl) return;

            const cal = new FullCalendar.Calendar(calEl, {
              initialView: 'dayGridMonth',
              height:      700,
              headerToolbar: {
                left:   'prev,next today',
                center: 'title',
                right:  'dayGridMonth,timeGridWeek,timeGridDay'
              },
              buttonText: {
                today: 'Today',
                month: 'Month',
                week:  'Week',
                day:   'Day'
              },
              events: fcEvents,

              eventClick: function({ event }) {
                const p = event.extendedProps;
                document.getElementById('modal-subject').textContent = event.title;
                document.getElementById('modal-details').innerHTML =
                  detailRow('fas fa-door-open',      'Room',        p.room)           +
                  detailRow('fas fa-circle-dot',     'Status',      p.status)         +
                  detailRow('fas fa-clock',          'Start',       fmt(event.start)) +
                  detailRow('fas fa-clock',          'End',         fmt(event.end))   +
                  detailRow('fas fa-user',           'Organizer',   p.organizer)      +
                  detailRow('fas fa-map-marker-alt', 'Location',    p.location)       +
                  detailRow('fas fa-align-left',     'Description', p.description);
                document.getElementById('bookingModal').style.display = 'flex';
              },

              dateClick: function({ date }) {
                openQuickBook(date);
              },

              eventMouseEnter: function(info) {
                info.el.style.transform  = 'translateY(-1px) scale(1.02)';
                info.el.style.transition = 'transform 0.15s';
                info.el.style.zIndex     = '10';
              },
              eventMouseLeave: function(info) {
                info.el.style.transform = '';
                info.el.style.zIndex    = '';
              }
            });

            cal.render();
            buildLegend();
          });

          window.openQuickBook = function(date) {
            const d   = new Date(date);
            const pad = n => String(n).padStart(2, '0');
            _selectedDate = `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;

            const friendly = d.toLocaleDateString('en-GB', {
              weekday: 'long', day: 'numeric', month: 'long', year: 'numeric'
            });
            document.getElementById('qb-date-heading').textContent  = `Book for ${friendly}`;
            document.getElementById('qb-date-display').textContent  = friendly;
            document.getElementById('quickBookModal').style.display = 'flex';
          };

          window.submitQuickBook = function() {
            if (!_selectedDate) return;
            const roomId = document.getElementById('qb-room').value;
            let url = `/Booking/Create?startDate=${encodeURIComponent(_selectedDate + 'T09:00')}`;
            if (roomId) url += `&roomId=${encodeURIComponent(roomId)}`;
            window.location.href = url;
          };

          window.closeModalOnBackdrop = function(e) {
            if (e.target.id === 'bookingModal')
              document.getElementById('bookingModal').style.display = 'none';
          };

          window.closeQuickBookBackdrop = function(e) {
            if (e.target.id === 'quickBookModal')
              document.getElementById('quickBookModal').style.display = 'none';
          };

        })();
    </script>
}