<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MeetSpace</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("HeadExtra", required: false)
</head>
<body>

    @{
        var userName = Context.Session.GetString("UserName");
        var userCompany = Context.Session.GetString("UserCompany");
        var userEmail = Context.Session.GetString("UserEmail");
        var isLoggedIn = !string.IsNullOrEmpty(userName);
    }

    @if (isLoggedIn)
    {
        <div id="logoutModal"
             style="display:none;position:fixed;inset:0;z-index:99999;
                  background:rgba(30,31,75,0.45);backdrop-filter:blur(6px);
                  align-items:center;justify-content:center"
             onclick="closeLogoutBackdrop(event)">
            <div style="background:var(--surface);border-radius:24px;
                    padding:2.5rem 2.2rem;max-width:400px;width:92%;
                    text-align:center;
                    box-shadow:0 24px 80px rgba(91,106,247,0.22);
                    border:1.5px solid var(--border);
                    animation:slideUp .3s cubic-bezier(.34,1.56,.64,1)">

                <div style="width:58px;height:58px;border-radius:50%;
                      background:rgba(91,106,247,0.08);
                      border:1.5px solid rgba(91,106,247,0.18);
                      display:flex;align-items:center;justify-content:center;
                      margin:0 auto 1.2rem;font-size:1.4rem">
                    👋
                </div>

                <h4 style="font-family:'Clash Display',sans-serif;font-size:1.2rem;
                     font-weight:700;color:var(--text);margin-bottom:.5rem">
                    Sign Out?
                </h4>
                <p style="color:var(--text-secondary);font-size:.9rem;
                    line-height:1.65;margin-bottom:1.8rem">
                    You are signed in as
                    <strong style="color:var(--text)">@userName</strong>.<br />
                    Are you sure you want to sign out?
                </p>

                <div class="d-flex gap-3">
                    <button type="button"
                            onclick="document.getElementById('logoutModal').style.display='none'"
                            style="flex:1;background:var(--surface2);
                           border:1.5px solid var(--border);
                           border-radius:var(--radius-sm);
                           font-family:'Nunito',sans-serif;
                           font-weight:700;font-size:.9rem;
                           padding:.65rem;color:var(--text);
                           cursor:pointer;transition:all .2s"
                            onmouseover="this.style.borderColor='var(--primary)';this.style.color='var(--primary)'"
                            onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text)'">
                        Stay Signed In
                    </button>
                    <a asp-controller="Auth" asp-action="Logout"
                       style="flex:1;
                      background:linear-gradient(135deg,var(--primary),var(--primary-dark));
                      border:none;border-radius:var(--radius-sm);
                      font-family:'Nunito',sans-serif;font-weight:700;
                      font-size:.9rem;padding:.65rem;color:#fff;
                      text-decoration:none;
                      display:flex;align-items:center;justify-content:center;gap:6px;
                      box-shadow:0 4px 14px rgba(91,106,247,0.3);
                      transition:all .2s"
                       onmouseover="this.style.transform='translateY(-1px)';this.style.boxShadow='0 8px 24px rgba(91,106,247,0.4)'"
                       onmouseout="this.style.transform='';this.style.boxShadow='0 4px 14px rgba(91,106,247,0.3)'">
                        <i class="fas fa-sign-out-alt"></i> Yes, Sign Out
                    </a>
                </div>

            </div>
        </div>
    }

    <nav class="navbar navbar-expand-lg navbar-light glass-nav fixed-top">
        <div class="container">

            <a class="navbar-brand brand-logo" asp-controller="Home" asp-action="Index">
                <i class="fas fa-calendar-check me-2"></i>MeetSpace
            </a>

            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    style="border-color:var(--border)">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                @if (isLoggedIn)
                {
                    <ul class="navbar-nav me-auto align-items-lg-center gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i>Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Booking" asp-action="Index">
                                <i class="fas fa-door-open me-1"></i>Rooms
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Booking" asp-action="MyBookings">
                                <i class="fas fa-calendar-alt me-1"></i>My Bookings
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Room" asp-action="Index">
                                <i class="fas fa-cog me-1"></i>Manage Rooms
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary ms-lg-2"
                               asp-controller="Booking" asp-action="Create"
                               style="font-size:.84rem;padding:.45rem 1.1rem">
                                <i class="fas fa-plus me-1"></i>Book Now
                            </a>
                        </li>
                    </ul>

                    <div class="dropdown ms-lg-3">
                        <button class="d-flex align-items-center gap-2 dropdown-toggle"
                                type="button"
                                data-bs-toggle="dropdown"
                                aria-expanded="false"
                                style="background:var(--surface2);
                             border:1.5px solid var(--border);
                             border-radius:40px;
                             padding:.38rem .9rem .38rem .5rem;
                             cursor:pointer;transition:all .2s;
                             font-family:'Nunito',sans-serif;"
                                onmouseover="this.style.borderColor='var(--primary)';this.style.background='var(--primary-light)'"
                                onmouseout="this.style.borderColor='var(--border)';this.style.background='var(--surface2)'">
                            <span style="width:30px;height:30px;border-radius:50%;
                             background:linear-gradient(135deg,var(--primary),var(--primary-dark));
                             display:flex;align-items:center;justify-content:center;
                             color:#fff;font-size:.75rem;font-weight:800;flex-shrink:0">
                                @(userName?.Length > 0 ? userName[0].ToString().ToUpper() : "U")
                            </span>
                            <span style="font-size:.83rem;font-weight:700;color:var(--text);
                             max-width:110px;overflow:hidden;
                             text-overflow:ellipsis;white-space:nowrap">
                                @userName
                            </span>
                        </button>

                        <ul class="dropdown-menu dropdown-menu-end shadow-sm"
                            style="border:1.5px solid var(--border);border-radius:16px;
                         padding:.5rem;min-width:220px;margin-top:.4rem;
                         font-family:'Nunito',sans-serif">

                            <li>
                                <div style="padding:.5rem .85rem .6rem;
                              border-bottom:1px solid var(--border);
                              margin-bottom:.4rem">
                                    <div style="font-size:.68rem;font-weight:800;
                                 text-transform:uppercase;letter-spacing:.08em;
                                 color:var(--text-secondary);margin-bottom:.25rem">
                                        Company
                                    </div>
                                    <div style="display:inline-flex;align-items:center;gap:6px;
                                 background:var(--primary-light);color:var(--primary);
                                 border-radius:20px;padding:3px 12px;
                                 font-size:.76rem;font-weight:800">
                                        <i class="fas fa-building" style="font-size:.68rem"></i>
                                        @userCompany
                                    </div>
                                </div>
                            </li>

                            <li>
                                <div style="padding:.3rem .85rem;font-size:.78rem;
                               color:var(--text-secondary);font-weight:600">
                                    <i class="fas fa-envelope me-2" style="opacity:.6"></i>
                                    @userEmail
                                </div>
                            </li>

                            <li>
                                <hr class="dropdown-divider"
                                    style="border-color:var(--border);margin:.4rem .5rem" />
                            </li>

                            <li>
                                <button type="button"
                                        onclick="document.getElementById('logoutModal').style.display='flex'"
                                        class="dropdown-item d-flex align-items-center gap-2"
                                        style="border-radius:10px;font-size:.84rem;font-weight:700;
                                 color:var(--danger);padding:.5rem .85rem;
                                 transition:background .15s;background:transparent;
                                 border:none;width:100%;cursor:pointer;
                                 font-family:'Nunito',sans-serif"
                                        onmouseover="this.style.background='rgba(239,68,68,0.07)'"
                                        onmouseout="this.style.background='transparent'">
                                    <i class="fas fa-sign-out-alt"></i>
                                    Sign Out
                                </button>
                            </li>

                        </ul>
                    </div>
                }
            </div>

        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="footer-light mt-5">
        <div class="container text-center py-4">
            <p class="mb-0" style="color:var(--text-secondary)">
                © 2025 MeetSpace — @(userCompany ?? "Smart Room Booking")
            </p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function closeLogoutBackdrop(e) {
          if (e.target.id === 'logoutModal')
            document.getElementById('logoutModal').style.display = 'none';
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>