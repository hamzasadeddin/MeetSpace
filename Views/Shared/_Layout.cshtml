<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MeetSpace</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("HeadExtra", required: false)
</head>
<body>

    @{
        var userName = Context.Session.GetString("UserName");
        var userCompany = Context.Session.GetString("UserCompany");
        var userEmail = Context.Session.GetString("UserEmail");
        var isLoggedIn = !string.IsNullOrEmpty(userName);
        var logoSrc = "data:image/jpeg;base64,";
    }

    @if (isLoggedIn)
    {
        <div id="logoutModal"
             style="display:none;position:fixed;inset:0;z-index:99999;
                  background:rgba(17,28,51,0.55);backdrop-filter:blur(6px);
                  align-items:center;justify-content:center"
             onclick="closeLogoutBackdrop(event)">
            <div style="background:var(--surface);border-radius:22px;
                    padding:2.5rem 2.2rem;max-width:400px;width:92%;
                    text-align:center;
                    box-shadow:0 24px 80px rgba(17,28,51,0.28);
                    border:1.5px solid var(--border)">
                <div style="width:58px;height:58px;border-radius:50%;
                      background:rgba(26,39,68,0.08);
                      border:1.5px solid rgba(26,39,68,0.15);
                      display:flex;align-items:center;justify-content:center;
                      margin:0 auto 1.2rem;font-size:1.4rem">
                    👋
                </div>
                <h4 style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;
                     font-weight:700;color:var(--text);margin-bottom:.5rem">
                    Sign Out?
                </h4>
                <p style="color:var(--text-secondary);font-size:.9rem;
                    line-height:1.65;margin-bottom:1.8rem">
                    You are signed in as <strong style="color:var(--text)">@userName</strong>.<br />
                    Are you sure you want to sign out?
                </p>
                <div class="d-flex gap-3">
                    <button type="button"
                            onclick="document.getElementById('logoutModal').style.display='none'"
                            style="flex:1;background:var(--surface2);border:1.5px solid var(--border);
                           border-radius:var(--radius-sm);font-family:'DM Sans',sans-serif;
                           font-weight:600;font-size:.9rem;padding:.65rem;color:var(--text);
                           cursor:pointer;transition:all .2s"
                            onmouseover="this.style.borderColor='var(--navy)';this.style.color='var(--navy)'"
                            onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text)'">
                        Stay Signed In
                    </button>
                    <a asp-controller="Auth" asp-action="Logout"
                       style="flex:1;background:linear-gradient(135deg,var(--gold),#b8923e);
                      border:none;border-radius:var(--radius-sm);
                      font-family:'DM Sans',sans-serif;font-weight:700;
                      font-size:.9rem;padding:.65rem;color:var(--navy-deep) !important;
                      text-decoration:none;display:flex;align-items:center;
                      justify-content:center;gap:6px;
                      box-shadow:var(--shadow-gold);transition:all .2s"
                       onmouseover="this.style.transform='translateY(-1px)'"
                       onmouseout="this.style.transform=''">
                        <i class="fas fa-sign-out-alt"></i> Yes, Sign Out
                    </a>
                </div>
            </div>
        </div>
    }

    <nav class="navbar navbar-expand-lg glass-nav fixed-top">
        <div class="container">
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    style="border-color:rgba(255,255,255,0.2)">
                <span class="navbar-toggler-icon" style="filter:invert(1)"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                @if (isLoggedIn)
                {
                    <ul class="navbar-nav me-auto align-items-lg-center gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fas fa-home me-1"></i>Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Booking" asp-action="Index">
                                <i class="fas fa-door-open me-1"></i>Rooms
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Booking" asp-action="MyBookings">
                                <i class="fas fa-calendar-alt me-1"></i>My Bookings
                            </a>
                        </li>
                        @if (Context.Session.GetString("UserRole") == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Room" asp-action="Index">
                                    <i class="fas fa-cog me-1"></i>Manage Rooms
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="btn btn-primary ms-lg-2"
                               asp-controller="Booking" asp-action="Create"
                               style="font-size:.84rem;padding:.45rem 1.2rem;color:var(--navy-deep) !important">
                                <i class="fas fa-plus me-1"></i>Book Now
                            </a>
                        </li>
                    </ul>
                    <div class="dropdown ms-lg-3">
                        <button class="d-flex align-items-center gap-2 dropdown-toggle"
                                type="button" data-bs-toggle="dropdown" aria-expanded="false"
                                style="background:rgba(255,255,255,0.08);border:1.5px solid rgba(255,255,255,0.15);
                             border-radius:40px;padding:.38rem .9rem .38rem .5rem;
                             cursor:pointer;transition:all .2s;font-family:'DM Sans',sans-serif"
                                onmouseover="this.style.borderColor='var(--gold)';this.style.background='rgba(201,168,76,0.12)'"
                                onmouseout="this.style.borderColor='rgba(255,255,255,0.15)';this.style.background='rgba(255,255,255,0.08)'">
                            <span style="width:30px;height:30px;border-radius:50%;
                             background:linear-gradient(135deg,var(--gold),#b8923e);
                             display:flex;align-items:center;justify-content:center;
                             color:var(--navy-deep);font-size:.75rem;font-weight:800;flex-shrink:0">
                                @(userName?.Length > 0 ? userName[0].ToString().ToUpper() : "U")
                            </span>
                            <span style="font-size:.83rem;font-weight:600;color:rgba(255,255,255,0.9);
                             max-width:110px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                                @userName
                            </span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow"
                            style="border:1.5px solid var(--border);border-radius:16px;
                         padding:.5rem;min-width:220px;margin-top:.5rem;
                         font-family:'DM Sans',sans-serif;box-shadow:var(--shadow-lg)">
                            <li>
                                <div style="padding:.5rem .85rem .6rem;border-bottom:1px solid var(--border);margin-bottom:.4rem">
                                    <div style="font-size:.66rem;font-weight:700;text-transform:uppercase;
                                 letter-spacing:.09em;color:var(--text-muted);margin-bottom:.3rem">
                                        Company
                                    </div>
                                    <div style="display:inline-flex;align-items:center;gap:6px;
                                 background:rgba(26,39,68,0.07);color:var(--navy);
                                 border-radius:20px;padding:3px 12px;
                                 font-size:.76rem;font-weight:700;border:1px solid var(--border-navy)">
                                        <i class="fas fa-building" style="font-size:.66rem"></i>@userCompany
                                    </div>
                                </div>
                            </li>
                            <li>
                                <div style="padding:.3rem .85rem;font-size:.78rem;color:var(--text-secondary);font-weight:500">
                                    <i class="fas fa-envelope me-2" style="opacity:.5"></i>@userEmail
                                </div>
                            </li>
                            <li><hr class="dropdown-divider" style="border-color:var(--border);margin:.4rem .5rem" /></li>
                            <li>
                                <button type="button"
                                        onclick="document.getElementById('logoutModal').style.display='flex'"
                                        class="dropdown-item d-flex align-items-center gap-2"
                                        style="border-radius:9px;font-size:.84rem;font-weight:600;
                                 color:var(--danger);padding:.5rem .85rem;
                                 transition:background .15s;background:transparent;
                                 border:none;width:100%;cursor:pointer;font-family:'DM Sans',sans-serif"
                                        onmouseover="this.style.background='rgba(185,28,28,0.07)'"
                                        onmouseout="this.style.background='transparent'">
                                    <i class="fas fa-sign-out-alt"></i> Sign Out
                                </button>
                            </li>
                        </ul>
                    </div>
                }
            </div>
        </div>
    </nav>

    <main>@RenderBody()</main>

    <footer class="footer-light mt-5">
        <div class="container py-4">
            <div class="d-flex flex-column flex-md-row align-items-center justify-content-between gap-3">
                <img src="@logoSrc" alt="Alayyan"
                     style="height:72px;width:auto;object-fit:contain;opacity:.92" />
                <p class="mb-0" style="color:rgba(255,255,255,0.45);font-size:.82rem">
                    © 2026 MeetSpace by Alayyan Group Technology
                </p>
                
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        function closeLogoutBackdrop(e) {
          if (e.target.id === 'logoutModal')
            document.getElementById('logoutModal').style.display = 'none';
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
