@model IEnumerable<MeetingRoomBooking.Models.MeetingRoom>
@{
    ViewData["Title"] = "Meeting Rooms";
    var icons = new[] { "🏢", "🚀", "👑", "🤝", "🔵", "🟣" };
    var occupied = (ViewBag.OccupiedRooms as List<string>) ?? new List<string>();
    int i = 0;
}

<div class="container" style="padding-top:100px; padding-bottom:60px;">

    <div class="section-header fade-up">
        <div class="section-badge">Our Spaces</div>
        <h2 class="section-title">Choose Your Meeting Room</h2>
        <p style="color:var(--text-secondary);margin-top:.5rem;font-size:.95rem">
            Live availability — statuses update in real time
        </p>
    </div>

    <div class="d-flex gap-3 justify-content-center mb-5 fade-up delay-1">
        <div style="display:inline-flex;align-items:center;gap:7px;font-size:.8rem;font-weight:700;color:var(--text-secondary)">
            <span style="width:9px;height:9px;border-radius:50%;background:var(--success);display:inline-block"></span>
            Available now
        </div>
        <div style="display:inline-flex;align-items:center;gap:7px;font-size:.8rem;font-weight:700;color:var(--text-secondary)">
            <span style="width:9px;height:9px;border-radius:50%;background:var(--danger);display:inline-block"></span>
            Currently occupied
        </div>
    </div>

    <div class="row g-4">
        @foreach (var room in Model)
        {
            var isOccupied = occupied.Contains(room.Room_Name);

            <div class="col-md-6 col-lg-4 fade-up" style="animation-delay:@(i * 0.08)s">
                <div class="glass-card room-card h-100 @(isOccupied ? "room-occupied" : "")">

                    <div class="room-icon"
                         style="@(isOccupied ? "background:linear-gradient(135deg,#fff5f5,#ffe4e4)" : "")">
                        @icons[i % icons.Length]
                        @if (isOccupied)
                        {
                            <span class="occupied-badge-overlay">IN USE</span>
                        }
                    </div>

                    <div class="p-4">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="mb-0 fw-bold" style="color:var(--text)">@room.Room_Name</h5>
                            <span class="capacity-badge">
                                <i class="fas fa-users me-1"></i>@room.Room_Capacity
                            </span>
                        </div>

                        <p class="mb-2" style="color:var(--text-secondary);font-size:.85rem">
                            <i class="fas fa-map-marker-alt me-1" style="color:var(--primary)"></i>
                            @room.Room_Location
                        </p>

                        @if (!string.IsNullOrEmpty(room.Room_Amenities))
                        {
                            <div class="d-flex flex-wrap gap-1 mb-3">
                                @foreach (var amenity in room.Room_Amenities.Split(','))
                                {
                                    <span class="amenity-tag">@amenity.Trim()</span>
                                }
                            </div>
                        }

                        <div class="d-flex align-items-center justify-content-between mt-3 pt-1"
                             style="border-top:1.5px solid var(--border)">
                            @if (isOccupied)
                            {
                                <div>
                                    <span class="status-busy d-flex align-items-center gap-1">
                                        <span style="width:7px;height:7px;border-radius:50%;background:var(--danger);display:inline-block;animation:blink 1.4s ease-in-out infinite"></span>
                                        Occupied now
                                    </span>
                                    <span style="font-size:.7rem;color:var(--text-secondary);display:block;margin-top:2px">
                                        Room is in use
                                    </span>
                                </div>
                                <a asp-controller="Booking" asp-action="Create"
                                   asp-route-roomId="@room.Room_Id"
                                   class="btn btn-sm"
                                   style="background:var(--accent-light);color:var(--accent);
                                                  border:1.5px solid rgba(255,127,80,0.3);
                                                  border-radius:9px;font-weight:700;font-size:.78rem;
                                                  padding:.38rem .9rem;transition:all .2s;white-space:nowrap"
                                   onmouseover="this.style.background='#ff7f50';this.style.color='#fff'"
                                   onmouseout="this.style.background='var(--accent-light)';this.style.color='var(--accent)'">
                                    <i class="fas fa-calendar-plus me-1"></i>Book Later
                                </a>
                            }
                            else
                            {
                                <span class="status-available d-flex align-items-center gap-1">
                                    <span style="width:7px;height:7px;border-radius:50%;background:var(--success);display:inline-block;animation:blink 1.4s ease-in-out infinite"></span>
                                    Available
                                </span>
                                <a asp-controller="Booking" asp-action="Create"
                                   asp-route-roomId="@room.Room_Id"
                                   class="btn btn-primary btn-sm">
                                    Book Now <i class="fas fa-arrow-right ms-1"></i>
                                </a>
                            }
                        </div>
                    </div>

                </div>
            </div>
            i++;
        }
    </div>
</div>